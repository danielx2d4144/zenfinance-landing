{
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/beta",
      "has": [
        {
          "type": "host",
          "value": "app.zenfinance.online"
        }
      ],
      "permanent": false
    }
  ]
}
