{
  "version": 2,
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/beta",
      "has": [
        {
          "type": "host",
          "value": "app.zenfinance.online"
        }
      ],
      "permanent": false
    }
  ]
}
